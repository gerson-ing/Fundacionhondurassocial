---
const premios = [
	{ nombre: 'Premio Global Resiliency Fund', entidad: 'International Youth Foundation, N. Conrad Hilton, Burberry (USA)', anio: 2021 },
	{ nombre: 'Finalista Premio Mujeres Adelante', entidad: 'Banco Ficohsa', anio: 2021 },
	{ nombre: 'Premios Indio Lempira a la Excelencia', entidad: 'Comunidad hondureña migrante en Barcelona', anio: 2019 },
	{ nombre: 'Reconocimiento Agente de Cambio', entidad: 'JCI San Pedro Sula', anio: 2018 },
	{ nombre: 'Premio Voces Vitales — Mujeres Transformando Honduras', entidad: 'Voces Vitales', anio: 2018 },
	{ nombre: 'Premio Quetglas', entidad: 'Un premio a la caridad hecha persona', anio: 2018 },
	{ nombre: 'Premio Honduras Innova', entidad: 'Gobierno de Honduras, UTH', anio: 2017 },
	{ nombre: 'Premio Reto Emprendedor', entidad: 'Centromype, SICA, Gobierno de Taiwán', anio: 2016 },
	{ nombre: 'Premio Yo Emprendedor', entidad: 'UNITEC, Laureate University, Youth Action Net', anio: 2013 },
];

const premiosOrdenados = [...premios].sort((a, b) => b.anio - a.anio);
---

<section id="premios" class="py-20 lg:py-28 bg-white">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="section-header text-center mb-20">
			<span class="text-secondary font-semibold text-sm uppercase tracking-wider">Reconocimientos</span>
			<h2 class="text-3xl sm:text-4xl lg:text-6xl font-extrabold text-gray-900 mt-3 tracking-tight">
				Una trayectoria de <span class="text-primary">compromiso</span>
			</h2>
			<p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">
				Más de una década reconocidos nacional e internacionalmente por nuestro impacto social.
			</p>
		</div>

		<div class="premios-grid relative max-w-5xl mx-auto">
			<div class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary/20 via-primary to-primary/20 lg:-translate-x-1/2" aria-hidden="true"></div>

			<div class="space-y-10 lg:space-y-16">
				{premiosOrdenados.map((premio, i) => {
					const isLeft = i % 2 === 0;
					return (
						<div class="premio-card gsap-hidden relative pl-14 lg:pl-0">
							<div class:list={[
								'absolute left-4 lg:left-1/2 top-4 w-4 h-4 rounded-full bg-primary ring-4 ring-white shadow-lg -translate-x-1/2 z-10 transition-transform duration-300',
								'group-hover:scale-125',
							]} aria-hidden="true">
								<div class="absolute inset-0 rounded-full bg-primary animate-ping opacity-30"></div>
							</div>

							<div class:list={[
								'group lg:w-[calc(50%-2rem)] flex',
								isLeft ? 'lg:mr-auto lg:pr-8 lg:justify-end' : 'lg:ml-auto lg:pl-8 lg:justify-start',
							]}>
								<div class:list={[
									'w-full bg-white rounded-2xl p-6 lg:p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 hover:border-primary/30 hover:-translate-y-1',
									isLeft ? 'lg:text-right' : 'lg:text-left',
								]}>
									<div class:list={[
										'flex items-center gap-3 mb-4',
										isLeft ? 'lg:justify-end' : 'lg:justify-start',
									]}>
										<span class="text-4xl lg:text-5xl font-extrabold text-primary leading-none">
											{premio.anio}
										</span>
										<div class="flex-1 h-px bg-gradient-to-r from-primary/40 to-transparent lg:hidden"></div>
									</div>
									<h3 class="text-lg lg:text-xl font-bold text-gray-900 mb-2 leading-tight group-hover:text-primary transition-colors">
										{premio.nombre}
									</h3>
									<p class="text-sm text-gray-500 leading-relaxed">
										{premio.entidad}
									</p>
								</div>
							</div>
						</div>
					);
				})}
			</div>
		</div>
	</div>
</section>
